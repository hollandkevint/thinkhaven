# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key
#
# Per-workload model tiers (see lib/ai/model-config.ts). Each workload has a
# built-in default; you only set these to override. Precedence:
#   ANTHROPIC_MODEL_<WORKLOAD>  >  ANTHROPIC_MODEL (global)  >  built-in default.
#
# Built-in defaults (cost-preservation posture — no frontier models by default):
#   synthesis (decision-record artifact) -> claude-sonnet-4-6
#   board     (adversarial board loop)   -> claude-sonnet-4-6
#   chat      (streaming elicitation)    -> claude-sonnet-4-6
#   util      (connection test/utility)  -> claude-haiku-4-5
#
# ANTHROPIC_MODEL is a global kill-switch: set it to force EVERY workload onto one model.
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# Per-workload overrides — the ONLY way frontier models (Fable 5 / Opus 4.8,
# 2-3x Sonnet pricing) reach production. Opt in deliberately, per workload:
# ANTHROPIC_MODEL_SYNTHESIS=claude-fable-5
# ANTHROPIC_MODEL_BOARD=claude-opus-4-8
# ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
# ANTHROPIC_MODEL_UTIL=claude-haiku-4-5
#
# Reasoning effort (output_config.effort: low|medium|high|max). Defaults:
# synthesis and board send "high"; chat/util omit it (API default, latency-lean).
# Only sent to models that support it (Fable 5, Opus 4.5+, Sonnet 4.6) — stripped
# automatically on others, so the kill-switch stays safe.
# ANTHROPIC_EFFORT_SYNTHESIS=max
# ANTHROPIC_EFFORT_BOARD=high

# OpenRouter Fallback (optional, server-only — never NEXT_PUBLIC)
# When set, the guest decision-record synthesis falls back to OpenRouter if the
# Anthropic call fails (credit exhausted, rate-limited, or 5xx). Absent = fallback off.
# The streaming/tool chat paths are NOT covered by this fallback.
# OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: override the fallback model (default anthropic/claude-sonnet-4)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# Optional: set to "openrouter" to force the OpenRouter path (local/testing only)
# AI_PROVIDER=openrouter

# PostHog Analytics (optional, no tracking without these)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Application Configuration
NEXT_PUBLIC_APP_URL=https://thinkhaven.co

# Google Authentication Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Monetization Flags (server-only, not exposed to client)
# MESSAGE_LIMIT_ENABLED: per-session message caps (default: true if omitted)
MESSAGE_LIMIT_ENABLED=true
# CREDIT_SYSTEM_ENABLED: per-session credit deduction (set 'true' when ready)
# CREDIT_SYSTEM_ENABLED=true

# Stripe Payment Link (generate in Stripe Dashboard, paste URL here)
# NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxx