# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key

# Application Configuration
NEXT_PUBLIC_APP_URL=https://thinkhaven.co

# Google Authentication Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Stripe Configuration (required when LAUNCH_MODE=false)
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Launch Mode Configuration (SLC Launch Period)
# Set to 'true' to bypass credit system and enable 20-message session limits
# Server-only variable (not exposed to client for security)
# Remove or set to 'false' after Stripe integration is complete
LAUNCH_MODE=true