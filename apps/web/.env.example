# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: Override the default model (claude-sonnet-4-20250514)
# Use claude-haiku-4-5-20251001 for 67% cost reduction
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Application Configuration
NEXT_PUBLIC_APP_URL=https://thinkhaven.co

# Google Authentication Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Launch Mode Configuration (SLC Launch Period)
# Set to 'true' to bypass credit system and enable 20-message session limits
# Server-only variable (not exposed to client for security)
# Remove or set to 'false' after Stripe integration is complete
LAUNCH_MODE=true