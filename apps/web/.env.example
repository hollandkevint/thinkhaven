# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: Override the default model (claude-sonnet-4-20250514)
# Use claude-haiku-4-5-20251001 for 67% cost reduction
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# PostHog Analytics (optional, no tracking without these)
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Application Configuration
NEXT_PUBLIC_APP_URL=https://thinkhaven.co

# Google Authentication Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Monetization Flags (server-only, not exposed to client)
# MESSAGE_LIMIT_ENABLED: per-session message caps (default: true if omitted)
MESSAGE_LIMIT_ENABLED=true
# CREDIT_SYSTEM_ENABLED: per-session credit deduction (set 'true' when ready)
# CREDIT_SYSTEM_ENABLED=true